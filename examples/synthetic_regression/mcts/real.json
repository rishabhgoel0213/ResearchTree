{
  "root_branch": "root",
  "worktree_root": "../worktrees",
  "artifact_root": "../artifacts",
  "branch_prefix": "mcts",
  "iteration_budget": 4,
  "selection": {
    "policy": "ucb_budgeted",
    "exploration_constant": 1.4,
    "widening_coefficient": 2.0,
    "widening_exponent": 0.5,
    "virtual_loss": 1.0
  },
  "expander": {
    "command": [
      "python3",
      "../../../../treegit/src/treegit/policies/codex.py",
      "--tmux",
      "--tmux-session-prefix",
      "sr-mcts",
      "--unsafe",
      "--cleanup-path",
      "__pycache__",
      "--cleanup-path",
      "score_runs",
      "--cleanup-path",
      ".pytest_cache",
      "--prompt-file",
      "../../mcts/prompt.md"
    ],
    "commit_message_template": "mcts expand {parent_branch} -> {branch}"
  },
  "objective": {
    "id": "synthetic_regression",
    "version": "v1-real",
    "command": [
      "pixi",
      "run",
      "--manifest-path",
      "../../pixi.toml",
      "python",
      "../../objectives/synthetic_regression_objective.py",
      "{worktree}",
      "--objective-version",
      "v1-real",
      "--output-root",
      "{artifact_root}",
      "--score-script",
      "../../score.py",
      "--env",
      "ITERATIONS=300"
    ],
    "default_direction": "minimize"
  }
}
