{
  "root_branch": "root",
  "worktree_root": "../worktrees",
  "artifact_root": "../artifacts",
  "branch_prefix": "mcts",
  "expansion_width": 5,
  "selection": {
    "policy": "uct",
    "exploration_constant": 1.4
  },
  "expander": {
    "command": [
      "python3",
      "../../../../treegit/src/treegit/policies/codex.py",
      "--tmux",
      "--tmux-session-prefix",
      "pg-mcts",
      "--unsafe",
      "--cleanup-path",
      "__pycache__",
      "--cleanup-path",
      "test_runs",
      "--cleanup-path",
      ".pytest_cache",
      "--prompt-file",
      "../../mcts/prompt.md"
    ],
    "commit_message_template": "mcts expand {parent_branch} -> {branch}"
  },
  "objective": {
    "id": "parameter_golf",
    "version": "v1-real",
    "command": [
      "python3",
      "../../objectives/parameter_golf_objective.py",
      "{worktree}",
      "--objective-version",
      "v1-real",
      "--output-root",
      "{artifact_root}",
      "--score-script",
      "../../score.py",
      "--data-path",
      "../../../../data/datasets/fineweb10B_sp1024",
      "--tokenizer-path",
      "../../../../data/tokenizers/fineweb_1024_bpe.model",
      "--env",
      "ITERATIONS=200",
      "--env",
      "WARMUP_STEPS=10",
      "--env",
      "WARMDOWN_ITERS=50",
      "--env",
      "MAX_WALLCLOCK_SECONDS=300",
      "--env",
      "TRAIN_BATCH_TOKENS=65536",
      "--env",
      "VAL_LOSS_EVERY=0",
      "--env",
      "TRAIN_LOG_EVERY=10",
      "--env",
      "MUON_BACKEND_STEPS=5"
    ],
    "default_direction": "minimize"
  }
}
